[pull]
	rebase = false
[credential]
	helper = store
[user]
	email = sae@eccles.dev
	name = Sophie Eccles
	signingkey = BE26B33008E7B09D

[init]
	defaultBranch = main
[advice]
	detachedHead = false
[commit]
	gpgsign = true
[tag]
	gpgsign = true
[push]
	followTags = true
[alias]
	graph = log --graph --oneline --all
	amend = commit --amend

[status]
	short = true
	branch = true
	aheadBehind = true
	renames = true
	showStash = true
	showUntrackedFiles = normal

[include]
	path = .local.gitconfig

